APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

AUDIT_WEBHOOK_RECEIVER_DRIVER=null
AUDIT_WEBHOOK_RECEIVER_LOG_CHANNEL=audit_webhook_receiver
AUDIT_WEBHOOK_RECEIVER_TOKEN=
AUDIT_WEBHOOK_LOCAL_ROUTES_ENABLED=true
AUDIT_WEBHOOK_RECEIVER_RETENTION_DAYS=14

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Ghostable Desktop license checkout
GHOSTABLE_STRIPE_PRICE_PERSONAL=
GHOSTABLE_STRIPE_PRICE_TEAM_5=
GHOSTABLE_STRIPE_PRICE_TEAM_10=
GHOSTABLE_LICENSE_CHECKOUT_SUCCESS_URL=
GHOSTABLE_LICENSE_CHECKOUT_CANCEL_URL=

# Ghostable Desktop platform downloads
DESKTOP_DOWNLOAD_WINDOWS_URL=
DESKTOP_DOWNLOAD_LINUX_URL=

DRATA_BASE_URL=https://api.drata.com
DRATA_API_KEY=null

VANTA_BASE_URL=https://api.vanta.com
VANTA_CLIENT_ID=null
VANTA_CLIENT_SECRET=null
VANTA_AUTHORIZE_URL=https://app.vanta.com/oauth/authorize
VANTA_TOKEN_URL=https://api.vanta.com/oauth/token
VANTA_SCOPE="connectors.self:read-resource connectors.self:write-resource"
VANTA_RESOURCE_ID=null
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Google Tags/Ads tracking
GOOGLE_TAG_ID=
GOOGLE_TAG_ACCOUNT_CREATED_LABEL=
GOOGLE_TAG_SUBSCRIPTION_STARTED_LABEL=
X_TAG_ID=
X_TAG_ACCOUNT_CREATED_EVENT_ID=
X_TAG_SUBSCRIPTION_STARTED_EVENT_ID=
